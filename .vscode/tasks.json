{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate Theme",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/.github/hooks/validate-theme.ps1",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Package Extension",
      "type": "shell",
      "command": "vsce package",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Extension",
      "type": "shell",
      "command": "code --extensionDevelopmentPath=${workspaceFolder}",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
