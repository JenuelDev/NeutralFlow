    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "comment.block",
                "comment.block.documentation",
                "comment.line",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#5c6370",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "support.variable",
                "variable.other.property",
                "variable.other.object.property",
                "entity.name.variable",
                "constant.other.placeholder",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#e06c75"
            }
        },
        {
            "name": "Colors",
            "scope": [
                "constant.other.color"
            ],
            "settings": {
                "foreground": "#56b6c2"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#f43753",
                "fontStyle": "bold italic"
            }
        },
        {
